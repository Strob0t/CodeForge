# -- Docs MCP Server ------------------------------
# API endpoint for embeddings (LM Studio, Ollama, OpenAI, etc.)
DOCS_MCP_API_BASE=http://host.docker.internal:1234/v1
DOCS_MCP_API_KEY=lmstudio
DOCS_MCP_EMBEDDING_MODEL=text-embedding-qwen3-embedding-8b

# -- Host Path (DevContainer bind mounts) -------
# Set this to the host-side project path when running in a DevContainer.
# The Docker daemon runs on the host, so bind mounts need host paths.
# HOST_PROJECT_PATH=/path/to/CodeForge

# -- CodeForge Core -----------------------------
# Port for the Go Core HTTP server (default: 8080)
# CODEFORGE_PORT=8080

# -- Internal Auth (worker-to-core) ----------------
# Shared secret for Python Worker -> Go Core API calls (routing stats, outcomes)
# Must match on both sides. Without this, worker HTTP calls return 401.
CODEFORGE_INTERNAL_KEY=  # REQUIRED: generate with: openssl rand -hex 32

# -- PostgreSQL ----------------------------------
# Password for PostgreSQL (shared by CodeForge + LiteLLM)
POSTGRES_PASSWORD=  # REQUIRED: set a strong password

# -- NATS JetStream --------------------------------
# URL for the NATS message queue
NATS_URL=nats://localhost:4222

# -- LiteLLM Proxy ---------------------------------
# Master key for LiteLLM Proxy authentication
LITELLM_MASTER_KEY=  # REQUIRED: generate with: openssl rand -hex 32

# -- LLM Provider API Keys (optional) ------------
# Configure the providers you want to use via LiteLLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
AIHUBMIX_API_KEY=
CEREBRAS_API_KEY=
CHUTES_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=
TOGETHERAI_API_KEY=
FIREWORKS_API_KEY=
GITHUB_TOKEN=

# -- Local Models ---------------------------------
# Ollama endpoint (auto-discovered via /v1/models)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# LM Studio endpoint (auto-discovered via /v1/models)
LM_STUDIO_API_BASE=http://host.docker.internal:1234/v1

# -- HuggingFace -----------------------------------
HF_TOKEN=
